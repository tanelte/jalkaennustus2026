# Copy to .env.local and fill in real values from `supabase start` output.
# Per Constitution Critical Rule 4: use the right pool mode.

# Transaction-pooled (PgBouncer). App code, Server Actions, Server Components.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Session-pooled (direct). Drizzle migrations, long-running scripts.
DATABASE_URL_ADMIN=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# NextAuth (wired in S02 — placeholder so future stories don't need to update this file).
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Live results feed (wired in S18 — placeholder).
FOOTBALL_DATA_API_KEY=

# Cron auth (wired in S16/S17/S18 — placeholder).
CRON_SECRET=
